{
  "name": "cursor-coworker",
  "version": "0.0.0",
  "description": "Delegate bounded coding work to an authenticated Cursor Agent CLI",
  "type": "module",
  "bin": { "cursor-coworker": "dist/src/cli.js" },
  "files": ["dist/src", "dist/bench", "docs/benchmark.md", "README.md", "LICENSE"],
  "engines": { "node": ">=22" },
  "repository": { "type": "git", "url": "git+https://github.com/RemyLespagnol/cursor-coworker.git" },
  "bugs": { "url": "https://github.com/RemyLespagnol/cursor-coworker/issues" },
  "homepage": "https://github.com/RemyLespagnol/cursor-coworker#readme",
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('node:fs').copyFileSync('bench/cases.readonly.json','dist/bench/cases.readonly.json')\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run build && npm test",
    "prebenchmark:run": "npm run build",
    "benchmark:run": "node dist/bench/run.js",
    "benchmark:validate": "node dist/bench/score.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "license": "MIT"
}
